# 复制为 backend/.env，后端启动时会自动加载。

# 本地调试模式。
APP_MODE=dev
GIN_MODE=debug
APP_PORT=8080

# 本地 MySQL 8 连接。
MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/alpha_pulse?charset=utf8mb4&parseTime=True&loc=Local

# Redis 为可选依赖；如果本机没有 Redis，可保持 ENABLE_REDIS_CACHE=false。
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
MARKET_SNAPSHOT_CACHE_TTL=5
ANALYSIS_VIEW_CACHE_TTL=15

# 本地调试默认关闭 Redis / Stream / Scheduler，减少依赖和后台任务噪音。
MARKET_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
AUTO_MIGRATE=true
ENABLE_REDIS_CACHE=false
ENABLE_STREAM_COLLECTOR=false
ENABLE_SCHEDULER=false
ALLOW_MOCK_BINANCE_DATA=true
SCHEDULER_INTERVAL_SECONDS=60

# 单用户登录拦截。公网部署时建议开启，并同步配置前端环境变量。
ENABLE_SINGLE_USER_AUTH=false
AUTH_USERNAME=alpha-admin
# 使用 bcrypt 哈希，不要存明文密码。
AUTH_PASSWORD_HASH=
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_SESSION_TTL_HOURS=168
AUTH_COOKIE_NAME=alpha_pulse_session
# 例如 .alpha-pulse.example.com；本地调试可留空。
AUTH_COOKIE_DOMAIN=
# 生产环境 HTTPS 建议设为 true。
AUTH_COOKIE_SECURE=false
# 公网部署时改成你的前端域名，例如 https://app.alpha-pulse.example.com
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 公开行情不强制要求密钥；如接入签名接口再填写。
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
