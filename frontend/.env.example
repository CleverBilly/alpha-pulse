NEXT_PUBLIC_API_BASE_URL=/api
# 可选：本地前后端分端口时，让 market snapshot websocket 直连后端。
NEXT_PUBLIC_MARKET_STREAM_BASE_URL=http://127.0.0.1:8080
# Next.js 在运行时把 /api/* 代理到这个后端地址。
API_PROXY_TARGET=http://127.0.0.1:8080
NEXT_PUBLIC_AUTH_ENABLED=false
# middleware 需要和后端保持一致。
AUTH_COOKIE_NAME=alpha_pulse_session
AUTH_SESSION_SECRET=replace-with-the-same-secret-as-backend
